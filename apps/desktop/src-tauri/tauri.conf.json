{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "snipebundle",
  "version": "0.1.1",
  "identifier": "fun.snipebundle.app",
  "build": {
    "beforeDevCommand": "pnpm --filter snipebundle-desktop dev",
    "beforeBuildCommand": "pnpm --filter snipebundle-desktop build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "snipebundle",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Finance",
    "shortDescription": "pump.fun launch sniper",
    "longDescription": "Snipe pump.fun token launches with Jito bundles. Configurable filters, targeted dev tracking, time-based exits.",
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
